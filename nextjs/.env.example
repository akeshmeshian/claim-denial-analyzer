# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Stripe keys — https://dashboard.stripe.com/apikeys (optional for test mode)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe webhook secret — set after configuring webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# Your app's public URL (used for Stripe redirect URLs)
# Replit: https://your-repl.replit.app
# Local:  http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internal test mode password — enables /test-upload (no payment required)
TEST_MODE_PASSWORD=your-secret-password

# Admin dashboard password — protects /admin
ADMIN_PASSWORD=your-admin-password
