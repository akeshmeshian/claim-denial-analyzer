# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Stripe keys — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe webhook secret — set after running: stripe listen --forward-to localhost:3000/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Your app's public URL (used for Stripe success/cancel redirect URLs)
# Leave empty to auto-detect in production
NEXT_PUBLIC_APP_URL=http://localhost:3000
